+
+  async getCompanyIntelligenceSummary(id: string): Promise<CompanyIntelligenceSummary | null> {
+    const detail = await this.getCompanyDetail(id);
+    if (!detail) return null;
+
+    const evidence = detail.qualification.evidence_payload ?? {};
+    const intelligenceConfidence = Math.round(((detail.qualification.source_confidence_score ?? 0) + ((detail.qualification.confidence_score ?? 0) * 100)) / 2);
+    const fitForStructuredCredit = Boolean(detail.qualification.fit_fidc || detail.qualification.fit_dcm);
+
+    return {
+      companyId: id,
+      rawDocumentCount: detail.monitoringOutputs.length,
+      factCount: Object.keys(evidence).length,
+      signalCount: detail.signals.length,
+      enrichmentSnapshotCount: 1,
+      topSignalTypes: detail.signals.slice(0, 5).map((signal) => signal.type),
+      topFactKeys: Object.keys(evidence).slice(0, 5),
+      inferredFlags: {
+        hasCreditProductEvidence: Boolean(detail.qualification.has_credit_product),
+        hasReceivablesEvidence: Boolean(detail.qualification.has_receivables),
+        hasFundingSignal: (detail.qualification.predicted_funding_need_score ?? 0) >= 60,
+        hasFidcEvidence: Boolean(detail.qualification.fit_fidc),
+        fitForStructuredCredit,
+      },
+      intelligenceConfidence,
+      recommendedNextStep: detail.company.nextAction,
+    };
+  }
+
+  async getCompanyDecisionMemo(id: string): Promise<CompanyDecisionMemo | null> {
+    const detail = await this.getCompanyDetail(id);
+    if (!detail) return null;
+
+    const intelligenceConfidence = Math.round(((detail.qualification.source_confidence_score ?? 0) + ((detail.qualification.confidence_score ?? 0) * 100)) / 2);
+    const whyNow = detail.signals[0]?.note ?? detail.monitoring.feedHighlights[0] ?? detail.qualification.capital_structure_rationale;
+    const fitForStructuredCredit = Boolean(detail.qualification.fit_fidc || detail.qualification.fit_dcm);
+
+    return {
+      companyId: id,
+      companyName: detail.company.name,
+      suggestedStructure: detail.qualification.suggested_structure_type,
+      qualificationScore: detail.scores.qualification,
+      leadScore: detail.scores.lead,
+      rankingScore: detail.scores.rankingScore,
+      triggerStrength: detail.qualification.trigger_strength_score,
+      intelligenceConfidence,
+      fitForStructuredCredit,
+      whyNow,
+      recommendedNextStep: detail.company.nextAction,
+      topSignals: detail.signals.slice(0, 3).map((signal) => signal.note),
+      topPatterns: detail.patterns.slice(0, 3).map((pattern) => pattern.patternName),
+      thesisSummary: detail.thesis.summary,
+    };
+  }
+
+  async getQualificationIntelligenceBridge(id: string): Promise<QualificationIntelligenceBridge | null> {
+    const detail = await this.getCompanyDetail(id);
+    if (!detail) return null;
+
+    const intelligenceConfidence = Math.round(((detail.qualification.source_confidence_score ?? 0) + ((detail.qualification.confidence_score ?? 0) * 100)) / 2);
+    const fitForStructuredCredit = Boolean(detail.qualification.fit_fidc || detail.qualification.fit_dcm);
+
+    return {
+      companyId: id,
+      qualificationScore: detail.scores.qualification,
+      intelligenceConfidence,
+      fitForStructuredCredit,
+      fitFidcHint: Boolean(detail.qualification.fit_fidc),
+      fitDcmHint: Boolean(detail.qualification.fit_dcm),
+      capitalNeedHint: (detail.qualification.predicted_funding_need_score ?? 0) >= 60,
+      receivablesHint: Boolean(detail.qualification.has_receivables),
+      recommendedCommercialAction: detail.company.nextAction,
+      recommendedStructuralAction: detail.qualification.suggested_structure_type,
+    };
+  }
+
+  async getMvpReadiness(): Promise<MvpReadinessSnapshot> {
+    const companies = await this.listCompanies();
+    const details = (await Promise.all(companies.map((company) => this.getCompanyDetail(company.id)))).filter(Boolean) as CompanyDetailView[];
+    const confidences = details.map((detail) => Math.round(((detail.qualification.source_confidence_score ?? 0) + ((detail.qualification.confidence_score ?? 0) * 100)) / 2));
+    const qualificationScores = details.map((detail) => detail.scores.qualification);
+    const leadScores = details.map((detail) => detail.scores.lead);
+    const companiesWithIntelligence = details.filter((detail) => detail.signals.length > 0 && detail.monitoringOutputs.length > 0).length;
+    const companiesFitForStructuredCredit = details.filter((detail) => detail.qualification.fit_fidc || detail.qualification.fit_dcm).length;
+    const avg = (values: number[]) => values.length ? Math.round(values.reduce((sum, value) => sum + value, 0) / values.length) : 0;
+
+    return {
+      companiesTracked: companies.length,
+      companiesWithIntelligence,
+      companiesFitForStructuredCredit,
+      avgIntelligenceConfidence: avg(confidences),
+      avgQualificationScore: avg(qualificationScores),
+      avgLeadScore: avg(leadScores),
+      topRecommendedActions: companies.slice(0, 5).map((company) => company.nextAction ?? 'Executar análise comercial'),
+      summary: `Base com ${companies.length} empresas, ${companiesFitForStructuredCredit} com fit de estrutura e ${companiesWithIntelligence} com inteligência operacional suficiente para abordagem.`,
+    };
+  }
 
