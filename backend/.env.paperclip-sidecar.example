# Paperclip Sidecar
PAPERCLIP_PORT=4010
PAPERCLIP_TARGET_API_BASE_URL=http://localhost:4000
PAPERCLIP_ENABLE_AUTH=false
PAPERCLIP_SHARED_SECRET=change-me
PAPERCLIP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4010

# Shared runtime
PORT=4000
USE_SUPABASE=true
BOOTSTRAP_SUPABASE=false
